.PHONY : src/target.s

# target to generate assembly for a file
src/target.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/zdbg_core.dir/build.make CMakeFiles/zdbg_core.dir/src/target.c.s
.PHONY : src/target.c.s

